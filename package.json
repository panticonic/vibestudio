{
  "type": "module",
  "name": "@panticonic/vibestudio",
  "productName": "Vibestudio",
  "version": "0.1.1",
  "private": true,
  "description": "A horizontally stacked panel app built with Electron and TypeScript",
  "main": "dist/main.cjs",
  "bin": {
    "vibestudio": "dist/cli/client.mjs",
    "vibestudio-server": "dist/server.mjs"
  },
  "scripts": {
    "build": "NODE_ENV=production node build.mjs",
    "bootstrap": "pnpm install && pnpm --dir workspace install",
    "bootstrap:frozen": "pnpm install --frozen-lockfile && pnpm --dir workspace install --frozen-lockfile",
    "install:userland": "pnpm --dir workspace install",
    "dev": "export NODE_ENV=development && node build.mjs && (pnpm type-check &) && node scripts/run-electron.mjs",
    "dev:webrtc": "NODE_ENV=development node scripts/dev-webrtc-remote.mjs",
    "cli": "VIBESTUDIO_SERVER_ENTRY=live tsx src/cli/client.ts",
    "start": "node scripts/run-electron.mjs",
    "headless-host": "VIBESTUDIO_HEADLESS_HOST=1 node scripts/run-electron.mjs --headless-host",
    "server": "node dist/server.mjs",
    "server:dev": "NODE_ENV=development node dist/server.mjs",
    "server:live": "tsx src/server/index.ts",
    "dev:self:server": "node scripts/start-dogfood-server.mjs",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:linux": "pnpm build && electron-builder --linux",
    "stage:npm": "pnpm build && node scripts/build-npm-packages.mjs",
    "setup:npm-token": "node scripts/setup-npm-token.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "publish:npm:staged": "node scripts/publish-npm.mjs --skip-build --skip-stage",
    "generate:brand-assets": "node scripts/generate-brand-assets.mjs",
    "generate:agent-docs": "node scripts/generate-agent-cli-docs.mjs",
    "check:agent-docs": "node scripts/generate-agent-cli-docs.mjs --check",
    "generate:runtime-docs": "node scripts/generate-runtime-docs.mjs",
    "check:runtime-docs": "node scripts/generate-runtime-docs.mjs --check",
    "check:build-artifacts": "node scripts/check-build-artifacts.mjs",
    "check:host-boundary": "node scripts/check-host-workspace-imports.mjs",
    "check:no-single-user": "node scripts/check-no-single-user.mjs",
    "type-check:cloudflare": "pnpm --dir apps/signaling typecheck && pnpm --dir apps/webhook-relay typecheck",
    "deploy:cloudflare:signaling": "pnpm --dir apps/signaling run deploy",
    "deploy:cloudflare:apex": "pnpm --dir apps/webhook-relay run deploy",
    "deploy:cloudflare": "pnpm deploy:cloudflare:signaling && pnpm deploy:cloudflare:apex",
    "smoke:cloudflare:apex": "node scripts/smoke-cloudflare-apex.mjs",
    "smoke:cloudflare:signaling": "node scripts/smoke-cloudflare-signaling.mjs",
    "smoke:cloudflare": "pnpm smoke:cloudflare:apex && pnpm smoke:cloudflare:signaling",
    "dev:debug": "VIBESTUDIO_DEBUG_PATHS=1 pnpm dev",
    "dev:verbose": "VIBESTUDIO_LOG_LEVEL=verbose pnpm dev",
    "terminal:jig": "node scripts/run-terminal-input-jig.mjs",
    "terminal:jig:smoke": "node scripts/terminal-input-jig-electron-smoke.mjs",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,html,json}'",
    "quality:check": "pnpm type-check && pnpm lint && pnpm format:check && pnpm check:host-boundary && pnpm check:no-single-user",
    "type-check": "pnpm type-check:host && pnpm type-check:userland && pnpm type-check:mobile",
    "type-check:host": "tsc --noEmit",
    "type-check:userland": "node scripts/require-userland-install.mjs && pnpm --dir workspace type-check",
    "type-check:mobile": "pnpm --dir apps/mobile type-check",
    "type-check:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "pnpm run check:runtime-docs && pnpm run check:agent-docs && pnpm run test:host && pnpm run test:browser && pnpm run test:userland && pnpm run test:mobile",
    "test:host": "vitest run --config vitest.host.config.ts",
    "test:userland": "node scripts/require-userland-install.mjs && pnpm --dir workspace test",
    "test:mobile": "pnpm --dir apps/mobile test --runInBand",
    "test:extension-smoke": "NODE_ENV=development node build.mjs && VIBESTUDIO_RUN_SERVER_INTEGRATION=1 vitest run tests/extension-image-service.integration.test.ts",
    "test:headless-panel-integration": "NODE_ENV=development node build.mjs && VIBESTUDIO_RUN_HEADLESS_PANEL_INTEGRATION=1 vitest run tests/headless-panel.integration.test.ts",
    "test:webrtc-e2e": "VIBESTUDIO_RUN_WEBRTC_E2E=1 vitest run tests/webrtc-native.e2e.test.ts tests/webrtc-system.e2e.test.ts",
    "test:desktop-pairing-smoke": "NODE_ENV=development node build.mjs && node scripts/desktop-pairing-smoke.mjs",
    "smoke:full": "node scripts/full-system-smoke.mjs",
    "test:terminal-app-smoke": "NODE_ENV=development node build.mjs && node scripts/terminal-app-smoke.mjs",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:e2e": "playwright test -c tests/config/playwright.config.ts",
    "test:e2e:headed": "playwright test -c tests/config/playwright.config.ts --headed",
    "test:all": "pnpm test && pnpm test:e2e",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "typescript",
    "panel"
  ],
  "author": "Gabriel Pickard",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "allowedBuilds": [
      "electron",
      "esbuild",
      "node-pty",
      "node-datachannel"
    ],
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "node-datachannel"
    ],
    "//overrides": "react-native 0.79 peerDeps react ^19.0.0. Pinning here prevents hoisted React 18 (pulled in transitively by workspace deps) from shadowing RN's requirement in the mobile bundle. protobufjs ^7.5.5 patches RCE GHSA-xq3m-2v4x-88gg reachable via @google/genai → pi-ai. Revisit when bumping RN.",
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@earendil-works/pi-ai": "0.80.6",
      "protobufjs": "^7.5.5"
    },
    "patchedDependencies": {
      "@earendil-works/pi-ai@0.80.6": "workspace/packages/harness/patches/@earendil-works__pi-ai@0.80.6.patch"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/npmcli__arborist": "^6.3.1",
    "@types/pacote": "^11.1.8",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/browser": "3.2.4",
    "buffer": "^6.0.3",
    "electron": "^39.2.5",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "esbuild-svelte": "^0.9.4",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "sql.js": "^1.14.0",
    "svelte": "^5.55.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-ai": "^0.80.6",
    "@ghostery/adblocker": "^2.13.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@vibestudio/browser-data": "workspace:*",
    "@vibestudio/credential-client": "workspace:*",
    "@vibestudio/dev-log": "workspace:*",
    "@vibestudio/durable": "workspace:*",
    "@vibestudio/env-paths": "workspace:*",
    "@vibestudio/extension": "workspace:*",
    "@vibestudio/extension-host": "workspace:*",
    "@vibestudio/git": "workspace:*",
    "@vibestudio/port-utils": "workspace:*",
    "@vibestudio/process-adapter": "workspace:*",
    "@vibestudio/rpc": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "@vibestudio/typecheck": "workspace:*",
    "@vibestudio/types": "workspace:*",
    "@npmcli/arborist": "^7.4.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/json-schema": "^7.0.15",
    "@types/ws": "^8.18.1",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.17.1",
    "chokidar": "^5.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.0",
    "firebase-admin": "^12.7.0",
    "isomorphic-git": "^1.30.1",
    "jotai": "^2.15.1",
    "node-datachannel": "^0.32.0",
    "node-pty": "^1.0.0",
    "npm": "^11.13.0",
    "p-limit": "^6.2.0",
    "pacote": "^21.0.0",
    "pathe": "^2.0.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tldts": "^7.0.19",
    "typescript": "^5.9.3",
    "workerd": "^1.20260310.1",
    "ws": "^8.18.3",
    "yaml": "^2.8.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.0"
  }
}
