{
  "name": "@workspace-apps/terminal-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "Vibestudio Terminal",
    "app": {
      "target": "terminal",
      "entry": "src/index.ts",
      "interactive": true,
      "capabilities": ["connection-management"]
    }
  },
  "dependencies": {
    "@vibestudio/rpc": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "@workspace/terminal-host-protocol": "workspace:*",
    "@xterm/headless": "^5.5.0",
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
