{
  "name": "@workspace-apps/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "//dependencies": "Keep react-native-webview pinned with apps/mobile; 13.17.0 makes JSX props resolve to never under our TS/React setup.",
  "vibestudio": {
    "displayName": "Vibestudio Mobile",
    "app": {
      "target": "react-native",
      "renderer": "App.tsx",
      "rnComponentName": "Vibestudio",
      "rnHostAbi": "rn-host-1",
      "capabilities": [
        "notifications",
        "keychain",
        "clipboard",
        "open-external",
        "panel-hosting"
      ]
    }
  },
  "dependencies": {
    "@vibestudio/browser-data": "workspace:*",
    "@vibestudio/mobile-webrtc": "workspace:*",
    "@vibestudio/rpc": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "@notifee/react-native": "^9.1.8",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-firebase/app": "^23.5.0",
    "@react-native-firebase/messaging": "^23.5.0",
    "@react-navigation/drawer": "^7.3.3",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.2.6",
    "jotai": "^2.15.1",
    "lucide-react-native": "^1.14.0",
    "path-browserify": "^1.0.1",
    "react": "^19.0.0",
    "react-native": "^0.79.2",
    "react-native-gesture-handler": "^2.25.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-keychain": "^9.2.2",
    "react-native-reanimated": "^3.17.5",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-svg": "^15.15.4",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.16.1"
  }
}
