{
  "name": "@workspace-extensions/pdf-ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "PDF Ingest",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": [
        "*"
      ],
      "dependencyMode": "external"
    },
    "authority": {
      "requests": [
        {
          "capability": "service:extensions.health",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.log",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.ready",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.readdir",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        }
      ],
      "delegations": []
    }
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@tesseract.js-data/eng": "^1.0.0",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0"
  }
}
