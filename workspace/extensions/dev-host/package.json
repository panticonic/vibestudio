            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.stat",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.writeFile",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:hubControl.pairDevice",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:hubControl.routeWorkspace",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
