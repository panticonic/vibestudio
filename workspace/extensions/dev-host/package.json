      "providerContracts": {
        "devHost": {
          "methods": [
            "prepare",
            "failPreparation",
            "launch",
            "status",
            "rebuild",
            "stop",
            "eval",
            "logs",
            "watch"
          ]
        }
      }
    }
  },
  "dependencies": {
    "@vibestudio/direct-client": "workspace:*",
    "@vibestudio/extension": "workspace:*",
    "@vibestudio/service-schemas": "workspace:*",
    "@vibestudio/shared": "workspace:*"
  }
