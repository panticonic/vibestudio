{
  "name": "@workspace-extensions/mobile-debug",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "Mobile Debug",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": [
        "onInvoke"
      ],
      "streamingMethods": [
        "logcat",
        "shell"
      ]
    },
    "authority": {
      "requests": [
        {
          "capability": "context.boundary",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "critical",
          "evidence": "intentional-broad"
        },
        {
          "capability": "user-approval.request",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        }
      ],
      "evalCeilings": []
    }
  },
  "dependencies": {}
}
