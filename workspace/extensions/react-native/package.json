{
  "name": "@workspace-extensions/react-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "React Native Build Provider",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": ["*"],
      "dependencyMode": "external",
      "streamingMethods": ["buildArtifact"],
      "contributes": {
        "buildTargets": ["react-native"]
      }
    }
  },
  "dependencies": {
    "@vibestudio/shared": "workspace:*"
  }
}
