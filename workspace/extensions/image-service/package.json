{
  "name": "@workspace-extensions/image-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "authority": {
      "requests": [
        {
          "capability": "service:extensions.health",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.log",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.ready",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        }
      ],
      "delegations": []
    },
    "displayName": "Image Service",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": [
        "*"
      ]
    }
  },
  "dependencies": {
    "@silvia-odwyer/photon-node": "^0.3.4"
  }
}
