{
  "name": "@workspace-extensions/test-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "authority": {
      "requests": [
        {
          "capability": "service:extensions.health",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.log",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.ready",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.ensureMaterialized",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:userlandApproval.request",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:workspace.getInfo",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        }
      ]
    },
    "displayName": "Workspace Test Runner",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "dependencyMode": "external",
      "activationEvents": [
        "*"
      ]
    }
  },
  "dependencies": {
    "vitest": "^3.2.2"
  }
}
