{
  "name": "@workspace-extensions/file-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "File Tools",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": [
        "*"
      ],
      "dependencyMode": "external"
    },
    "authority": {
      "requests": [
        {
          "capability": "service:extensions.health",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.log",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:extensions.ready",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.ensureMaterialized",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.open",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.readFile",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.realpath",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:fs.stat",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        }
      ],
      "delegations": []
    }
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  }
}
