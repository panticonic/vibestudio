{
  "name": "@workspace-extensions/file-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "displayName": "File Tools",
    "entry": "index.ts",
    "sourcemap": true,
    "extension": {
      "activationEvents": [
        "onInvoke"
      ],
      "dependencyMode": "external"
    },
    "authority": {
      "requests": [
        {
          "capability": "context.boundary",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "critical",
          "evidence": "intentional-broad"
        }
      ],
      "evalCeilings": []
    }
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0"
  }
}
