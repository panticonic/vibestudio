{
  "name": "@workspace-about/permissions",
  "version": "0.1.0",
  "private": true,
  "vibestudio": {
    "title": "Permissions",
    "description": "Review and revoke saved app and agent permissions",
    "hiddenInLauncher": false,
    "autoArchiveWhenEmpty": true,
    "authority": {
      "requests": [
        {
          "capability": "service:permissions.list",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        },
        {
          "capability": "service:permissions.revoke",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          }
        }
      ],
      "delegations": []
    }
  },
  "dependencies": {
    "@workspace/runtime": "workspace:*",
    "@workspace/about-shared": "workspace:*"
  },
  "type": "module"
}
