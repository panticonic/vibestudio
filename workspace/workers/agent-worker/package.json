{
  "name": "@workspace-workers/agent-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "entry": "index.ts",
    "durable": {
      "classes": [
        {
          "className": "AiChatWorker"
        }
      ]
    },
    "agent": {
      "displayName": "Chat Agent",
      "description": "General-purpose coding & chat agent",
      "icon": "💬"
    },
    "exposeModules": [
      "@workspace/runtime",
      "@workspace/pubsub",
      "zod"
    ],
    "authority": {
      "requests": [
        {
          "capability": "accounts.connect",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "agent.credentials.manage",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "automations.register",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "context.boundary",
          "resource": {
            "kind": "prefix",
            "prefix": "context"
          },
          "tier": "critical",
          "evidence": "bounded-dynamic"
        },
        {
          "capability": "context.clone",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "context.materialize",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "credential.use",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "internal-model-runtime.use",
          "resource": {
            "kind": "exact",
            "key": "local-models"
          },
          "tier": "gated",
          "evidence": "exact"
        },
        {
          "capability": "network.response.read",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "subagents.create",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "user-approval.request",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "workspace-main-advance",
          "resource": {
            "kind": "prefix",
            "prefix": "workspace-source-change:"
          },
          "tier": "gated",
          "evidence": "bounded-dynamic"
        },
        {
          "capability": "workspace-service:channel",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "workspace-service:gad.workspace",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        },
        {
          "capability": "workspace-service:models",
          "resource": {
            "kind": "prefix",
            "prefix": ""
          },
          "tier": "gated",
          "evidence": "intentional-broad"
        }
      ]
    }
  },
  "dependencies": {
    "@workspace/runtime": "workspace:*",
    "@workspace/agentic-do": "workspace:*",
    "@workspace/pubsub": "workspace:*",
    "@workspace/harness": "workspace:*",
    "zod": "^3.24.0"
  }
}
