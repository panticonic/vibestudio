{
  "name": "@workspace-workers/silent-agent-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "entry": "index.ts",
    "durable": {
      "classes": [{ "className": "SilentAgentWorker" }]
    },
    "exposeModules": [
      "@workspace/runtime",
      "@workspace/pubsub",
      "zod"
