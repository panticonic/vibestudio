{
  "name": "@workspace-workers/gmail-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "natstack": {
    "entry": "index.ts",
    "durable": {
      "classes": [{ "className": "GmailAgentWorker" }]
    },
    "agent": {
      "displayName": "Gmail Agent",
      "description": "Reads and triages your Gmail",
      "icon": "📧",
      "defaultConfig": {
        "handle": "gmail",
        "respondPolicy": "mentioned-or-followup"
      }
    },
    "exposeModules": [
      "@earendil-works/pi-ai",
      "@workspace/runtime",
      "@workspace/pubsub",
      "@workspace/gmail",
      "zod"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@workspace/runtime": "workspace:*",
    "@workspace/agentic-do": "workspace:*",
    "@workspace/agentic-protocol": "workspace:*",
    "@workspace/gmail": "workspace:*",
    "@workspace/pubsub": "workspace:*",
    "@workspace/harness": "workspace:*",
    "zod": "^3.24.0"
  }
}
