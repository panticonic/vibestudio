{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "rootDir": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@vibestudio/browser-data": ["packages/browser-data/src/index.ts"],
      "@vibestudio/browser-data/client": ["packages/browser-data/src/client.ts"],
      "@vibestudio/credential-client": ["packages/credential-client/src/index.ts"],
      "@vibestudio/credential-client/*": ["packages/credential-client/src/*"],
      "@vibestudio/context-workspace": ["packages/context-workspace/src/index.ts"],
      "@vibestudio/dev-log": ["packages/dev-log/src/index.ts"],
      "@vibestudio/direct-client": ["packages/direct-client/src/index.ts"],
      "@vibestudio/direct-client/webrtc": ["packages/direct-client/src/webrtcClient.ts"],
      "@vibestudio/direct-client/node-webrtc": ["packages/direct-client/src/nodeDatachannelPeer.ts"],
      "@vibestudio/direct-client/cert": ["packages/direct-client/src/cert.ts"],
      "@vibestudio/durable": ["packages/durable/src/index.ts"],
      "@vibestudio/durable/test-utils": ["packages/durable/src/test-utils.ts"],
      "@vibestudio/env-paths": ["packages/env-paths/src/index.ts"],
      "@vibestudio/extension": ["packages/extension/src/index.ts"],
      "@vibestudio/extension-host": ["packages/extension-host/src/index.ts"],
      "@vibestudio/extension-host/child-runtime": ["packages/extension-host/src/childRuntime.ts"],
      "@vibestudio/git": ["packages/git/src/index.ts"],
      "@vibestudio/git/formatting": ["packages/git/src/formatting.ts"],
      "@vibestudio/identity/*": ["packages/identity/src/*"],
      "@vibestudio/process-adapter": ["packages/process-adapter/src/index.ts"],
      "@vibestudio/rpc": ["packages/rpc/src/index.ts"],
      "@vibestudio/rpc/*": ["packages/rpc/src/*"],
      "@vibestudio/service-schemas/bindings/*": ["packages/service-schemas/src/bindings/*"],
      "@vibestudio/service-schemas/clients/*": ["packages/service-schemas/src/clients/*"],
      "@vibestudio/service-schemas/runtime/*": ["packages/service-schemas/src/runtime/*"],
      "@vibestudio/service-schemas/*": ["packages/service-schemas/src/*"],
      "@vibestudio/shell-core/*": ["packages/shell-core/src/*"],
      "@vibestudio/shared/*": ["packages/shared/src/*"],
      "@vibestudio/sqlite": ["packages/sqlite/src/index.ts"],
      "@vibestudio/typecheck": ["packages/typecheck/src/index.ts"],
      "@vibestudio/unit-host": ["packages/unit-host/src/index.ts"],
      "@vibestudio/types": ["packages/types/src/index.ts"],
      "@vibestudio/workspace/*": ["packages/workspace/src/*"],
      "@vibestudio/workspace-contracts/*": ["packages/workspace-contracts/src/*"]
    }
  },
  "include": ["src/**/*", "packages/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist",
    "packages/mobile-webrtc",
    "src/server/workerdPrograms",
    "src/server/services/relaySeam.integration.test.ts"
  ]
}
