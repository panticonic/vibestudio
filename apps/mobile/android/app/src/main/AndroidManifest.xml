<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true">

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="approvals"
            tools:replace="android:value" />

        <service
            android:name="io.invertase.firebase.messaging.ReactNativeFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name=".OAuthLoopbackKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">

            <!-- Main launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- vibestudio://connect onboarding and vibestudio://panel navigation links. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="vibestudio"
                    android:host="connect" />
                <data
                    android:scheme="vibestudio"
                    android:host="panel" />
            </intent-filter>

            <!--
                Verified Android App Link for OAuth callbacks. With
                android:autoVerify="true" + a valid assetlinks.json served
                from https://vibestudio.app/.well-known/assetlinks.json
                (served by apps/webhook-relay), Android binds this
                intent-filter to *only* this app's signing certificate.
                Other apps registering the same host cannot intercept the
                authorization code. See
                docs/audit/08-mobile-supply-chain.md H-1 / H-2.

                Verify post-install with:
                  adb shell pm get-app-links app.vibestudio.mobile
                Expected state for vibestudio.app: `verified`.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="vibestudio.app"
                    android:pathPrefix="/oauth/" />
                <data
                    android:scheme="https"
                    android:host="vibestudio.app"
                    android:path="/pair" />
                <data
                    android:scheme="https"
                    android:host="vibestudio.app"
                    android:path="/panel" />
            </intent-filter>
        </activity>
    </application>
</manifest>
