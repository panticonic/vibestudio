{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@vibestudio/shared/*": ["../../packages/shared/src/*"],
      "@vibestudio/service-schemas/*": ["../../packages/service-schemas/src/*"],
      "@vibestudio/shell-core/*": ["../../packages/shell-core/src/*"],
      "@vibestudio/workspace-contracts/*": ["../../packages/workspace-contracts/src/*"],
      "@vibestudio/dev-log": ["../../packages/dev-log/src/index.ts"],
      "@vibestudio/env-paths": ["../../packages/env-paths/src/index.ts"],
      "@vibestudio/browser-data": ["../../packages/browser-data/src/index.ts"],
      "@vibestudio/browser-data/client": ["../../packages/browser-data/src/client.ts"],
      "@vibestudio/rpc": ["../../packages/rpc/src/index.ts"],
      "@vibestudio/rpc/*": ["../../packages/rpc/src/*"],
      "@vibestudio/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["../../workspace/apps/mobile/**/*", "src/**/*"],
  "exclude": [
    "node_modules",
    "ios",
    "android",
    "../../workspace/apps/mobile/jest.setup.ts",
    "../../workspace/apps/mobile/**/*.test.ts",
    "../../workspace/apps/mobile/**/*.test.tsx"
  ]
}
