{
  "name": "@vibestudio/browser-data",
  "version": "0.1.0",
  "description": "Shared browser data contracts, storage schema, and shell RPC client for Vibestudio",
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-output"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "default": "./dist/storage/index.js"
    },
    "./source-reader-internals": {
      "types": "./dist/sourceReaderInternals.d.ts",
      "default": "./dist/sourceReaderInternals.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibestudio/service-schemas": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ]
}
