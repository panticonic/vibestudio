{
  "name": "@vibestudio/process-adapter",
  "version": "0.1.0",
  "description": "Process spawning abstraction (Electron utilityProcess / Node.js child_process)",
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-output"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "test": "cd ../.. && vitest run packages/process-adapter/src"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
