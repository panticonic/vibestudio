{
  "name": "@vibestudio/extension",
  "version": "0.1.0",
  "description": "Vibestudio extension authoring types",
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-output"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "@vibestudio/service-schemas": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "@vibestudio/unit-host": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
