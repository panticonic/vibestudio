{
  "name": "@vibestudio/git",
  "version": "0.1.0",
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-output"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./formatting": {
      "types": "./dist/formatting.d.ts",
      "default": "./dist/formatting.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "test": "cd ../.. && vitest run packages/git/src"
  },
  "dependencies": {
    "@vibestudio/types": "workspace:*",
    "diff": "^7.0.0",
    "isomorphic-git": "^1.36.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
