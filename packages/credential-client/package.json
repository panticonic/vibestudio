{
  "name": "@vibestudio/credential-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-output"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "cd ../.. && vitest run packages/credential-client/src"
  },
  "dependencies": {
    "@vibestudio/env-paths": "workspace:*",
    "@vibestudio/rpc": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
