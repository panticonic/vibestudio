{
  "name": "@vibestudio/typecheck",
  "version": "0.1.0",
  "description": "TypeScript type checking for Vibestudio panels and workers",
  "type": "module",
  "vibestudio": {
    "buildProfile": "tsc-build"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json --force",
    "dev": "tsc --build tsconfig.build.json --watch",
    "test": "cd ../.. && vitest run packages/typecheck/src"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
