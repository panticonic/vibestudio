{
  "name": "@vibestudio/extension-host",
  "version": "0.1.0",
  "description": "Vibestudio extension host, registry, and child runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./child-runtime": {
      "types": "./dist/childRuntime.d.ts",
      "default": "./dist/childRuntime.js"
    }
  },
  "scripts": {
    "build": "node build.mjs"
  },
  "dependencies": {
    "@vibestudio/credential-client": "workspace:*",
    "@vibestudio/extension": "workspace:*",
    "@vibestudio/process-adapter": "workspace:*",
    "@vibestudio/rpc": "workspace:*",
    "@vibestudio/shared": "workspace:*",
    "@vibestudio/unit-host": "workspace:*",
    "yaml": "^2.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
